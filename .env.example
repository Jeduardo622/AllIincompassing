#########################################
# Environment configuration template
#
# Copy this file to `.env.codex` (preferred) or `.env` before running local
# scripts. The runtime loader in `src/server/env.ts` defaults to `.env.codex`,
# so keep that filename when possible.
#
# Never commit real secrets. Replace every `****` placeholder with project-
# specific values stored in Codex Secrets or your local shell exports.
#########################################

# ---------------------------------------------------------------------------
# Client-safe Supabase configuration
# These values are safe to expose in browser bundles and may also be echoed
# as Vite `VITE_*` variables when building the front end.
# Populate these with the preview branch credentials Supabase generates for
# each pull request (see `docs/supabase_branching.md`).
# ---------------------------------------------------------------------------
SUPABASE_URL=****
SUPABASE_ANON_KEY=****
SUPABASE_EDGE_URL=****

# Optional Vite mirrors for the browser bundle (keep in sync with the values
# above if you surface them through Vite's import.meta.env API).
VITE_SUPABASE_URL=****
VITE_SUPABASE_ANON_KEY=****
VITE_SUPABASE_EDGE_URL=****

# ---------------------------------------------------------------------------
# Server-only Supabase secrets
# These must remain on the server: do not embed them in front-end bundles or
# check them into source control.
# Preview databases issue a dedicated service-role key per branch—use that key
# when running database-integrated tests locally.
# ---------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=****
SUPABASE_ACCESS_TOKEN=****
# Direct database connection string used by scripts/check-database-*.js.
# Use the hosted Supabase connection URL; do not use localhost.
DATABASE_URL=****
SUPABASE_DB_URL=****
# Dashboard analytics role provisioning lives in docs/roles/dashboard_consumer.md.
# No additional env vars are required, but keep the documentation handy for deploy steps.

# ---------------------------------------------------------------------------
# AI + third-party integrations (server-only)
# Keep these secrets in secure storage; the `.env.codex` loader will surface
# them to backend utilities only.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=****
OPENAI_ORGANIZATION=****

# AWS / S3 configuration
AWS_REGION=****
AWS_S3_BUCKET=****
AWS_ACCESS_KEY_ID=****
AWS_SECRET_ACCESS_KEY=****

# Email provider (SMTP) configuration
SMTP_HOST=****
SMTP_PORT=****
SMTP_USERNAME=****
SMTP_PASSWORD=****

# ---------------------------------------------------------------------------
# Slack alerting (CI + ops notifications)
# Populate with your Slack app/webhook details.
# ---------------------------------------------------------------------------
SLACK_WEBHOOK_URL=****
SLACK_ALERTS_CHANNEL=#deployments

# ---------------------------------------------------------------------------
# Playwright therapist authorization smoke (no secrets here)
# Provide account identifiers in plaintext; keep passwords in your secret store.
# ---------------------------------------------------------------------------
PW_THERAPIST_EMAIL=therapist.playwright+preview@example.com
PW_THERAPIST_PASSWORD=****
PW_ADMIN_EMAIL=admin@test.com
PW_ADMIN_PASSWORD=****
PW_SUPERADMIN_EMAIL=superadmin@test.com
PW_SUPERADMIN_PASSWORD=****
PW_FOREIGN_THERAPIST_ID=00000000-0000-0000-0000-000000000000
PW_FOREIGN_CLIENT_ID=00000000-0000-0000-0000-000000000000

# ---------------------------------------------------------------------------
# Production health / verification script configuration
# ---------------------------------------------------------------------------
# Base URL checked by scripts/production-health-check.js
PRODUCTION_URL=https://velvety-cendol-dae4d6.netlify.app
# Comma-separated paths appended to PRODUCTION_URL for endpoint probes.
PRODUCTION_HEALTH_PATHS=/,/start,/login,/dashboard
# Enable expensive Supabase schema drift diff in verify-auth script only where
# Docker/linked DB tooling is available.
RUN_SCHEMA_DIFF=false

# Edge function CORS allowlist
# Comma-separated origins, first origin is used as response allow-origin.
# Use localhost in dev and deployed URLs in staging/production.
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://velvety-cendol-dae4d6.netlify.app
APP_ENV=development

# Dashboard API fallback is disabled by default for safer auth behavior.
# Enable only for local/debug workflows that require a seeded default org fallback.
DASHBOARD_ALLOW_DEFAULT_ORG_FALLBACK=false

# Optional override for Playwright script env loading order.
# If set, this file is loaded first before .env/.env.local/.env.codex.
# PLAYWRIGHT_ENV_FILE=.env
