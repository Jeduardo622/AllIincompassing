{
  "name": "allincompassing",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:clean": "node scripts/clear-dev-cache.js && vite",
    "git:branch:audit": "tsx scripts/git-branch-audit.ts",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "clear-cache": "node scripts/clear-dev-cache.js",
    "test": "node scripts/run-vitest.mjs",
    "test:auth": "vitest run --reporter=verbose --config vitest.config.ts src/lib/__tests__/auth.test.ts",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:ci": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('coverage/.tmp', { recursive: true, force: true }); rmSync('coverage/coverage-summary.json', { force: true });\" && vitest run --coverage --run --reporter=verbose --coverage.reporter=json-summary && node scripts/ci/report-test-reliability.mjs",
    "verify:local": "npm run ci:check-focused && npm run lint && npm run typecheck && npm run test:ci && npm run ci:verify-coverage && npm run build && npm run test:routes:tier0",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "playwright:auth": "tsx scripts/playwright-auth-smoke.ts",
    "playwright:schedule-fixtures:setup": "tsx scripts/playwright-scheduling-fixtures.ts --action=setup",
    "playwright:schedule-fixtures:cleanup": "tsx scripts/playwright-scheduling-fixtures.ts --action=cleanup",
    "playwright:schedule-conflict": "tsx scripts/playwright-schedule-conflict.ts",
    "playwright:therapist-onboarding": "tsx scripts/playwright-therapist-onboarding.ts",
    "playwright:therapist-authorization": "tsx scripts/playwright-therapist-authorization.ts",
    "playwright:authorizations-read-scope": "tsx scripts/playwright-authorizations-read-scope-smoke.ts",
    "playwright:mobile-role-smoke": "tsx scripts/playwright-mobile-role-smoke.ts",
    "playwright:preflight": "tsx scripts/playwright-preflight.ts",
    "playwright:session-lifecycle": "tsx scripts/playwright-session-lifecycle.ts",
    "playwright:session-complete": "tsx scripts/playwright-session-complete.ts",
    "playwright:schedule-blocked-close": "tsx scripts/playwright-schedule-blocked-close.ts",
    "ci:playwright": "npm run playwright:preflight && npm run playwright:auth && npm run playwright:schedule-conflict && npm run playwright:therapist-onboarding && npm run playwright:therapist-authorization && npm run playwright:session-lifecycle && npm run playwright:session-complete && npm run playwright:schedule-blocked-close",
    "contract:runtime-config": "node scripts/contracts/check-runtime-config.mjs",
    "bolt:dev": "vite --host 0.0.0.0",
    "bolt:build": "tsc && vite build --mode production",
    "db:branch:create": "node scripts/create-supabase-branch.js",
    "db:branch:cleanup": "node scripts/cleanup-supabase-branch.js",
    "db:check:security": "node scripts/check-database-security.js",
    "db:check:performance": "node scripts/check-database-performance.js",
    "db:health:report": "node scripts/generate-health-report.js",
    "db:health:production": "node scripts/production-health-check.js",
    "pipeline:health": "npm run db:check:security && npm run db:check:performance && npm run db:health:report",
    "verify-auth": "node scripts/verify-auth-system.js",
    "audit:routes": "node scripts/route-audit.cjs",
    "fix:routes": "node scripts/fix-route-mismatches.js",
    "test:routes": "tsx scripts/run-cypress.ts",
    "test:routes:tier0": "tsx scripts/run-cypress.ts --spec cypress/e2e/routes_integrity.cy.ts,cypress/e2e/role_access.cy.ts,cypress/e2e/auth-roles.cy.ts",
    "test:routes:open": "cypress open --spec cypress/e2e/routes_integrity.cy.ts",
    "bolt:sync:create": "node scripts/bolt-new-sync.js create",
    "bolt:sync:from": "node scripts/bolt-new-sync.js sync",
    "auth:fix": "node scripts/apply-auth-fixes.js",
    "auth:test": "node scripts/test-super-admin-creation.js",
    "audit:service-role": "node scripts/audit-service-role-usage.cjs",
    "alert:slack": "tsx scripts/alerts/slack-webhook.ts",
    "alert:slack:test": "tsx scripts/alerts/verify-slack-webhook.ts",
    "validate:client-supabase": "tsx scripts/scan-client-supabase.ts",
    "preview:build": "tsx scripts/preview-build.ts",
    "preview:smoke": "tsx scripts/run-preview-smoke.ts",
    "preview:smoke:remote": "tsx scripts/smoke-preview.ts",
    "reconcile:therapist-docs": "tsx scripts/reconcile-therapist-documents.ts",
    "reconcile:therapist-docs:apply": "tsx scripts/reconcile-therapist-documents.ts --apply --fix-storage --fix-manifest --max-actions 50",
    "reconcile:therapist-docs:scheduled": "tsx scripts/reconcile-therapist-documents.ts --fail-on-orphans",
    "build:canary": "node scripts/ci/build-canary.mjs",
    "typegen": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > src/lib/db.types.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "ci:secrets": "tsx scripts/check-secrets.ts",
    "ci:check-focused": "node scripts/ci/run-policy-checks.mjs",
    "ci:check:api-boundary": "node scripts/ci/check-api-boundary.mjs",
    "ci:check:startup-canary": "node scripts/ci/check-startup-canary.mjs",
    "ci:check:rls-policy-coverage": "node scripts/ci/check-rls-policy-coverage.mjs",
    "ci:check:supabase-preview-drift": "node scripts/ci/check-supabase-preview-drift.mjs",
    "ci:check:api-convergence": "node scripts/ci/check-api-convergence.mjs",
    "ci:check:migrations": "node scripts/ci/check-migration-governance.mjs",
    "ci:check:test-reliability": "node scripts/ci/check-test-reliability.mjs",
    "ci:check:e2e-reliability": "node scripts/ci/check-e2e-reliability-gates.mjs",
    "ci:check:architecture-pack": "node scripts/ci/check-architecture-pack-freshness.mjs",
    "ci:check:p2-performance": "node scripts/ci/check-p2-performance.mjs",
    "ci:deploy:session-edge-bundle": "node scripts/ci/deploy-session-edge-bundle.mjs",
    "ci:touch:architecture-pack": "node scripts/ci/touch-architecture-pack-review-date.mjs",
    "ci:report:test-reliability": "node scripts/ci/report-test-reliability.mjs",
    "ci:report:api-cutover": "node scripts/ci/report-api-cutover-status.mjs",
    "ci:report:migration-health": "node scripts/ci/generate-migration-catalog.mjs && node scripts/ci/generate-migration-health-report.mjs",
    "ci:write-evidence": "node scripts/ci/write-success-evidence.mjs",
    "ci:rollback-drill": "node scripts/ci/run-rollback-drill.mjs",
    "ci:verify-coverage": "node scripts/ci/verify-coverage.mjs",
    "migration:new": "node scripts/migrations/new-migration-with-header.mjs",
    "validate:tenant": "npx tsx scripts/check-tenant-safety.ts",
    "perf:p2:baseline": "node scripts/perf/capture-p2-baseline.mjs",
    "perf:p2:check": "node scripts/ci/check-p2-performance.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.99.0",
    "@tanstack/react-query": "^5.90.21",
    "chart.js": "^4.5.1",
    "date-fns": "^3.3.1",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.5.0",
    "geolib": "^3.3.4",
    "isomorphic-dompurify": "^3.1.0",
    "lucide-react": "^0.344.0",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.2",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.30.3",
    "zod": "^3.25.74",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.27",
    "axe-core": "^4.11.1",
    "cypress": "^13.17.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.9.0",
    "husky": "^9.1.4",
    "jest-axe": "^8.0.0",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "serve-handler": "^6.1.7",
    "supabase": "^2.77.1",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  }
}
